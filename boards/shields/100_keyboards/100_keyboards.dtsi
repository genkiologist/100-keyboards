#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
        diode-direction = "row2col"; // ダイオードの向きを指定

        col-gpios
            = <&gpio0 22 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // COL0
            , <&gpio1 14 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // COL1
            , <&gpio0 23 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // COL2
            , <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // COL3
            , <&gpio1 0  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> // COL4
            ;

        row-gpios
            = <&gpio0 5  (GPIO_ACTIVE_HIGH)> // ROW0
            , <&gpio0 0  (GPIO_ACTIVE_HIGH)> // ROW1
            , <&gpio0 30 (GPIO_ACTIVE_HIGH)> // ROW2
            , <&gpio0 3  (GPIO_ACTIVE_HIGH)> // ROW3
            ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <25>; // 5列 × 5パーツ = 全体で25列
        rows = <4>;     // 行数は4のまま

        // 全体のキーの並び順（RC(行, 列) の形式で指定）
        // 左から右へ: Central, Peri_1, Peri_2, Peri_3, Peri_4 の順で並べた場合
        map = <
        /* Central (0-4) */  /* Peri 1 (5-9) */   /* Peri 2 (10-14) */ /* Peri 3 (15-19) */ /* Peri 4 (20-24) */
        RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)   RC(0,5)  RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)   RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14)   RC(0,15) RC(0,16) RC(0,17) RC(0,18) RC(0,19)   RC(0,20) RC(0,21) RC(0,22) RC(0,23) RC(0,24)
        RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)   RC(1,5)  RC(1,6)  RC(1,7)  RC(1,8)  RC(1,9)   RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14)   RC(1,15) RC(1,16) RC(1,17) RC(1,18) RC(1,19)   RC(1,20) RC(1,21) RC(1,22) RC(1,23) RC(1,24)
        RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)   RC(2,5)  RC(2,6)  RC(2,7)  RC(2,8)  RC(2,9)   RC(2,10) RC(2,11) RC(2,12) RC(2,13) RC(2,14)   RC(2,15) RC(2,16) RC(2,17) RC(2,18) RC(2,19)   RC(2,20) RC(2,21) RC(2,22) RC(2,23) RC(2,24)
        RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)   RC(3,5)  RC(3,6)  RC(3,7)  RC(3,8)  RC(3,9)   RC(3,10) RC(3,11) RC(3,12) RC(3,13) RC(3,14)   RC(3,15) RC(3,16) RC(3,17) RC(3,18) RC(3,19)   RC(3,20) RC(3,21) RC(3,22) RC(3,23) RC(3,24)
        >;
    };
};
